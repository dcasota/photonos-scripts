{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug photonos-package-report (fixture tree)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/photonos-package-report",
            "args": [
                "-workingDir", "${workspaceFolder}/tests/fixtures",
                "--dump-tasks", "photon-fixture"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "preLaunchTask": "Build (Debug)",
            "setupCommands": [
                { "description": "Enable pretty-printing for gdb",
                  "text": "-enable-pretty-printing",
                  "ignoreFailures": true }
            ]
        },
        {
