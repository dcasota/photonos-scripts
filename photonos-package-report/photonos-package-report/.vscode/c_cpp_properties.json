{
    "version": 4,
    "configurations": [
        {
            "name": "Photon (Linux, gcc, C11)",
            "includePath": [
                "${workspaceFolder}/include",
                "${workspaceFolder}/build/generated",
                "/usr/include/pcre2",
                "/usr/include"
            ],
            "defines": [
                "_GNU_SOURCE"
            ],
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c11",
            "intelliSenseMode": "linux-gcc-x64",
            "compileCommands": "${workspaceFolder}/build/compile_commands.json"
        }
    ]
}
