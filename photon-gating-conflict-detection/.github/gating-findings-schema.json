{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Photon OS Gating Conflict Findings",
  "description": "Machine-readable output from gating-detector agent",
  "type": "object",
  "required": ["metadata", "inventory_ref", "findings", "traceability"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["timestamp", "base_dir", "branches_scanned", "arch", "agent_version"],
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "base_dir": { "type": "string" },
        "branches_scanned": { "type": "array", "items": { "type": "string" } },
        "arch": { "type": "string", "enum": ["x86_64", "aarch64"] },
        "agent_version": { "type": "string" },
        "check_urls_enabled": { "type": "boolean" },
        "total_specs_scanned": { "type": "integer" },
        "total_gated_specs": { "type": "integer" }
      }
    },
    "inventory_ref": {
      "type": "string",
      "description": "Path to gating-inventory.json produced in Phase 0"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "constellation", "severity", "branch", "description", "remediation"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^C[0-9]+-",
            "description": "Unique finding identifier (e.g., C3-5.0-systemd-dfd7ac5e)"
          },
          "constellation": {
            "type": "string",
            "enum": ["C1", "C2", "C3", "C4", "C5", "C6"]
          },
          "severity": {
            "type": "string",
            "enum": ["BLOCKING", "CRITICAL", "HIGH", "WARNING", "INFO"]
          },
          "branch": { "type": "string" },
          "subrelease": { "oneOf": [{ "type": "integer" }, { "type": "string" }] },
          "package": { "type": "string" },
          "description": { "type": "string" },
          "spec_paths": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "description": "At least one spec file path must be referenced"
          },
          "missing_subpackages": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Required for C1 findings"
          },
          "dependent_specs": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Specs that depend on the missing packages"
          },
          "canister_version": {
            "type": "string",
            "description": "Required for C5 findings"
          },
          "http_status": {
            "type": "integer",
            "description": "Required for C6 findings"
          },
          "url": {
            "type": "string",
            "description": "Required for C6 findings"
          },
          "available_snapshots": {
            "type": "array",
            "items": { "type": "integer" },
            "description": "For C6: nearby available snapshot numbers"
          },
          "threshold": {
            "type": "integer",
            "description": "The build_if gating threshold value"
          },
          "remediation": {
            "type": "object",
            "required": ["action", "config_keys"],
            "properties": {
              "action": {
                "type": "string",
                "description": "Human-readable remediation action"
              },
              "config_keys": {
                "type": "array",
                "items": { "type": "string" },
                "description": "build-config.json keys relevant to the fix"
              }
            }
          }
        }
      }
    },
    "traceability": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["finding_id", "blast_radius"],
        "properties": {
          "finding_id": { "type": "string" },
          "blast_radius": {
            "type": "object",
            "properties": {
              "spec": { "type": "string" },
              "subpackages": { "type": "array", "items": { "type": "string" } },
              "consuming_specs": { "type": "array", "items": { "type": "string" } },
              "branches": { "type": "array", "items": { "type": "string" } },
              "snapshots": { "type": "array", "items": { "type": "integer" } },
              "architectures": { "type": "array", "items": { "type": "string" } },
              "flavors": {
                "type": "array",
                "items": { "type": "string", "enum": ["minimal", "full", "fips"] }
              }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "total_findings": { "type": "integer" },
        "by_severity": {
          "type": "object",
          "properties": {
            "BLOCKING": { "type": "integer" },
            "CRITICAL": { "type": "integer" },
            "HIGH": { "type": "integer" },
            "WARNING": { "type": "integer" },
            "INFO": { "type": "integer" }
          }
        },
        "by_constellation": {
          "type": "object",
          "properties": {
            "C1": { "type": "integer" },
            "C2": { "type": "integer" },
            "C3": { "type": "integer" },
            "C4": { "type": "integer" },
            "C5": { "type": "integer" },
            "C6": { "type": "integer" }
          }
        },
        "branches_affected": { "type": "array", "items": { "type": "string" } },
        "build_can_proceed": { "type": "boolean" }
      }
    }
  }
}
