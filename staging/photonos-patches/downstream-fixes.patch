diff --git a/SPECS/stig-hardening/fix-selinux-relabel-first-boot.patch b/SPECS/stig-hardening/fix-selinux-relabel-first-boot.patch
new file mode 100644
index 000000000..51d37fe16
--- /dev/null
+++ b/SPECS/stig-hardening/fix-selinux-relabel-first-boot.patch
@@ -0,0 +1,84 @@
+From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
+From: Factory AI Bot <factory-droid[bot]@users.noreply.github.com>
+Date: Thu, 09 Apr 2026 15:00:00 +0200
+Subject: [PATCH] Add first-boot SELinux filesystem relabel service
+
+Install a oneshot systemd service (selinux-relabel.service) that
+runs 'restorecon -R /' on first boot when /.selinux-relabel exists.
+
+The installer kernel has SELinux compiled in but boots with no
+policy loaded, so lsetxattr for security.selinux returns EINVAL --
+install-time labeling is not possible. Files created or modified by
+the STIG Ansible playbook during installation therefore have no
+SELinux labels (unlabeled_t). When the installed system boots with
+SELINUX=enforcing, confined processes are denied access to these
+files, breaking login, networking, and audit.
+
+The service runs After=local-fs.target Before=getty-pre.target so
+the filesystem is relabeled before the login prompt appears. It
+removes its trigger file on completion and is a no-op on subsequent
+boots.
+
+Known limitation: on systemd v257 (Photon 5.0 subrelease >= 92),
+early services (auditd, systemd-sysctl, systemd-networkd) may race
+with the relabel and fail on first boot. Login itself works. A
+reboot resolves all failures. See PR description for fix options.
+
+Signed-off-by: Factory AI Bot <factory-droid[bot]@users.noreply.github.com>
+---
+diff -ruN a/files/selinux-relabel.service b/files/selinux-relabel.service
+--- a/files/selinux-relabel.service	1970-01-01 01:00:00.000000000 +0100
++++ b/files/selinux-relabel.service	2026-04-09 14:10:05.308254403 +0200
+@@ -0,0 +1,15 @@
++[Unit]
++Description=SELinux Relabel Filesystem (first boot)
++DefaultDependencies=no
++After=local-fs.target
++Before=getty-pre.target sysinit.target
++ConditionPathExists=/.selinux-relabel
++
++[Service]
++Type=oneshot
++ExecStart=/usr/sbin/restorecon -R -e /proc -e /sys -e /dev /
++ExecStartPost=/usr/bin/rm -f /.selinux-relabel
++TimeoutSec=0
++
++[Install]
++WantedBy=sysinit.target
+diff -ruN a/tasks/photon.yml b/tasks/photon.yml
+--- a/tasks/photon.yml	2026-04-09 14:10:05.298254183 +0200
++++ b/tasks/photon.yml	2026-04-09 14:10:05.308254403 +0200
+@@ -2405,3 +2405,31 @@
+         - aidecheckoutput.rc is defined
+         - aidecheckoutput.rc != 0
+         - aideinstalled.stdout != ""
++
++###################################################################################################################################
++# SELinux relabel - must be the very last task so all file changes are included
++- name: Relabel filesystem for SELinux on first boot
++  tags: [selinux_relabel]
++  block:
++    - name: Check if SELinux enforcing is configured
++      ansible.builtin.command: grep -q '^SELINUX=enforcing' /etc/selinux/config
++      register: selinux_enforcing
++      failed_when: false
++      changed_when: false
++
++    - name: Install SELinux relabel service
++      ansible.builtin.copy:
++        src: selinux-relabel.service
++        dest: /usr/lib/systemd/system/selinux-relabel.service
++        owner: root
++        group: root
++        mode: "0644"
++      when: selinux_enforcing.rc == 0
++
++    - name: Enable SELinux relabel service
++      ansible.builtin.command: systemctl enable selinux-relabel.service
++      when: selinux_enforcing.rc == 0
++
++    - name: Create SELinux relabel trigger file
++      ansible.builtin.command: touch /.selinux-relabel
++      when: selinux_enforcing.rc == 0
+-- 
+2.43.7
diff --git a/SPECS/stig-hardening/fix-stig-playbook-fips-pam.patch b/SPECS/stig-hardening/fix-stig-playbook-fips-pam.patch
new file mode 100644
index 000000000..c0fde335c
--- /dev/null
+++ b/SPECS/stig-hardening/fix-stig-playbook-fips-pam.patch
@@ -0,0 +1,79 @@
+From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
+From: Factory AI Bot <factory-droid[bot]@users.noreply.github.com>
+Date: Thu, 02 Apr 2026 15:00:00 +0200
+Subject: [PATCH] Fix STIG playbook: PAM stack, FIPS module config, IMA hash
+
+1) Fix PHTN-50-000192 pam_faillock.so setup: regex_search() in
+   set_fact returns None when no match. The comparison
+   'preauthsearch == ""' evaluates to False when preauthsearch is
+   None, causing the cleanup step to be skipped while add steps
+   still run, corrupting the PAM auth stack with duplicate entries.
+   Use '| default("")' so None is treated as empty string.
+   (Backward-compatible: no-op when value is already a string on
+   older Ansible.)
+
+2) Add ima_hash=sha256 kernel parameter when fips=1 is active.
+   FIPS mode disables sha1 but IMA defaults to sha1, causing
+   allocation failures during boot.
+
+3) Generate /etc/ssl/fipsmodule.cnf via 'openssl fipsinstall' when
+   the FIPS provider module is present but fipsmodule.cnf is missing.
+   Without it, booting with fips=1 causes OpenSSL to fail to
+   initialize FIPS mode and pam_unix.so cannot verify passwords.
+
+Signed-off-by: Factory AI Bot <factory-droid[bot]@users.noreply.github.com>
+---
+diff -ruN a/tasks/photon.yml b/tasks/photon.yml
+--- a/tasks/photon.yml	2026-04-02 14:09:20.577266299 +0200
++++ b/tasks/photon.yml	2026-04-02 14:10:05.298254183 +0200
+@@ -305,6 +305,17 @@
+         - run_openssl_fips_install | bool
+         - opensslfipsinstalled.stdout == ""
+ 
++    - name: PHTN-50-000013 - Check if FIPS module is present
++      ansible.builtin.stat:
++        path: /usr/lib/ossl-modules/fips.so
++      register: fips_module_file
++
++    - name: PHTN-50-000013 - Generate FIPS module config if missing
++      ansible.builtin.command: openssl fipsinstall -out /etc/ssl/fipsmodule.cnf -module /usr/lib/ossl-modules/fips.so
++      args:
++        creates: /etc/ssl/fipsmodule.cnf
++      when: fips_module_file.stat.exists
++
+ ###################################################################################################################################
+ - name: PHTN-50-000014 - Configure auditd.conf write_logs
+   tags: [PHTN-50-000014, auditd]
+@@ -1183,6 +1194,12 @@
+         regexp: '^(\s*linux(?!.* fips=).*)'
+         replace: '\1 fips=1'
+ 
++    - name: PHTN-50-000182 - Add ima_hash=sha256 when fips=1 is active
++      ansible.builtin.replace:
++        path: '{{ var_grub_conf_file }}'
++        regexp: '^(\s*linux(?!.* ima_hash=).*fips=1.*)'
++        replace: '\1 ima_hash=sha256'
++
+     - name: PHTN-50-000080 - Replace fips=1 in /boot/grub2/grub.cfg
+       ansible.builtin.replace:
+         path: '{{ var_grub_conf_file }}'
+@@ -1320,7 +1337,7 @@
+         state: absent
+         regexp: '^auth\s+(required|requisite|\[default=die\])\s+pam_faillock\.so.*$'
+       when:
+-        - preauthsearch == "" or authfailsearch == ""
++        - preauthsearch | default('') == "" or authfailsearch | default('') == ""
+ 
+     - name: Ensure pam_unix.so auth control is 'sufficient' in system-auth if it is 'required'
+       ansible.builtin.replace:
+@@ -1375,7 +1392,7 @@
+         module_path: pam_faillock.so
+         state: absent
+       when:
+-        - sysaccountsearch == ""
++        - sysaccountsearch | default('') == ""
+ 
+     - name: PHTN-50-000192 - Add pam_faillock.so to system-account if it doesn't exist
+       community.general.pamd:
+-- 
+2.43.7
